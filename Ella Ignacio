<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ella Joy Ignacio — YouTube Growth & Content Operations</title>
<!-- Google Fonts for High-End Editorial Typography Hierarchy -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
  /* PREMIUM SYSTEM LAYOUT VARIABLES */
  :root {
    --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    
    /* Premium Cream & Dusty Rose Palette (Light Mode Base) */
    --bg: #faf7f2;        
    --bg-alt: #f3ede2;    
    --card: #ffffff;      
    --border: #e6dcce;    
    --text: #3d2f28;      
    --text-dim: #8c7a6b;  
    --accent: #f29da5;    
    --accent-dim: #df848d;
    --accent-ink: #ffffff;
    --shadow: rgba(61, 47, 39, 0.04);
    --shadow-hover: rgba(61, 47, 39, 0.08);
    --glass-bg: rgba(255, 255, 255, 0.4);
    --glass-border: rgba(255, 255, 255, 0.6);
  }

  /* Sophisticated Luxury Palette (Dark Mode Overrides) */
  [data-theme="dark"] {
    --bg: #0f0d0b;        
    --bg-alt: #171412;    
    --card: #1c1815;      
    --border: #2e2621;    
    --text: #f5f0eb;      
    --text-dim: #b0a296;  
    --accent: #f5aeb5;    
    --accent-dim: #f29da5;
    --accent-ink: #1c1815;
    --shadow: rgba(0, 0, 0, 0.2);
    --shadow-hover: rgba(0, 0, 0, 0.3);
    --glass-bg: rgba(28, 24, 21, 0.4);
    --glass-border: rgba(46, 38, 33, 0.6);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 90px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: "Plus Jakarta Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
    transition: background var(--transition), color var(--transition);
  }

  a { color: inherit; text-decoration: none; transition: var(--transition); }
  .wrap { max-width: 1140px; margin: 0 auto; padding: 0 24px; }

  /* NAVIGATION BAR WITH INTEGRATED TOGGLE BUTTON */
  header {
    position: sticky; top: 0; z-index: 1000;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    transition: background var(--transition), border-color var(--transition);
  }

  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 0; gap: 24px;
  }

  .logo {
    font-family: "Playfair Display", Georgia, serif;
    font-weight: 700; font-size: 22px; letter-spacing: -0.01em;
  }
  .logo span {
    font-family: "Alex Brush", cursive;
    color: var(--accent); font-weight: 400; font-size: 32px;
    vertical-align: middle; margin-left: 2px;
  }
  
  .nav-right-container { display: flex; align-items: center; gap: 32px; }
  .nav-links { display: flex; gap: 32px; font-size: 14px; font-weight: 500; color: var(--text-dim); }
  .nav-links a:hover { color: var(--text); }
  
  .nav-cta {
    border: 1px solid var(--accent); color: var(--accent);
    padding: 10px 22px; border-radius: 999px; font-size: 14px; font-weight: 600;
  }
  .nav-cta:hover { background: var(--accent); color: var(--accent-ink); transform: translateY(-1px); }

  /* LIGHT / DARK ENGINE SWITCH BUTTON */
  .theme-toggle-btn {
    background: none; border: 1px solid var(--border); cursor: pointer;
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--text); transition: var(--transition);
  }
  .theme-toggle-btn:hover { border-color: var(--accent); background: var(--card); }
  .theme-toggle-btn .sun-icon { display: none; font-size: 16px; }
  .theme-toggle-btn .moon-icon { display: block; font-size: 16px; }
  [data-theme="dark"] .theme-toggle-btn .sun-icon { display: block; }
  [data-theme="dark"] .theme-toggle-btn .moon-icon { display: none; }

  /* INTERSECTION OBSERVER ANIMATION ENGINES */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
  
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  }

  /* SECTION PRIMERS */
  section { padding: 100px 0; }
  .section-tag {
    display: inline-block; font-size: 12px; color: var(--accent);
    letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; font-weight: 700;
  }
  h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(30px, 4.5vw, 44px); font-weight: 700; letter-spacing: -0.01em;
    line-height: 1.2; margin-bottom: 16px;
  }
  .section-intro { color: var(--text-dim); max-width: 620px; font-size: 17px; margin-bottom: 56px; }

  /* HERO AREA FRAME */
  .hero { padding: 140px 0 100px; border-bottom: 1px solid var(--border); }
  .hero-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 64px; align-items: center; }
  
  .photo-frame {
    background: var(--card); border: 1px solid var(--border); border-radius: 24px;
    aspect-ratio: 4/5; display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; color: var(--text-dim); font-size: 14px; text-align: center; padding: 32px;
    box-shadow: 0 10px 30px var(--shadow); position: relative; overflow: hidden;
  }
  .photo-frame .ph-icon {
    width: 56px; height: 56px; border-radius: 50%; background: rgba(242, 157, 165, 0.12);
    color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 24px;
  }

  .eyebrow-container {
    display: inline-block; font-size: 13px; color: var(--accent);
    letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 24px;
    border: 1px solid var(--border); padding: 6px 16px; border-radius: 999px;
    background: var(--card); font-weight: 600;
  }

  h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;
    margin-bottom: 24px;
  }
  h1 span.accent { color: var(--accent); font-style: italic; font-weight: 400; }
  
  .hero p.sub { font-size: 19px; color: var(--text-dim); max-width: 580px; margin-bottom: 40px; }
  .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }

  .btn-primary {
    background: var(--accent); color: var(--accent-ink); font-weight: 700;
    padding: 16px 32px; border-radius: 999px; font-size: 15px;
    display: inline-block; transition: var(--transition);
    box-shadow: 0 6px 20px rgba(242, 157, 165, 0.25);
  }
  .btn-primary:hover { background: var(--accent-dim); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(242, 157, 165, 0.35); }

  .btn-secondary {
    border: 1px solid var(--border); color: var(--text); background: var(--card);
    padding: 16px 32px; border-radius: 999px; font-size: 15px;
    display: inline-block; transition: var(--transition);
  }
  .btn-secondary:hover { border-color: var(--accent); transform: translateY(-2px); background: var(--bg); }

  .stats {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
    margin-top: 64px; padding-top: 40px; border-top: 1px solid var(--border);
  }
  .stat-num { font-size: 36px; font-weight: 700; color: var(--accent); font-family: "Playfair Display", serif; }
  .stat-label { font-size: 13px; color: var(--text-dim); margin-top: 6px; font-weight: 500; }

  /* ABOUT SNAPSHOT SECTION */
  .about { background: var(--bg-alt); border-bottom: 1px solid var(--border); }
  .about-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: start; }
  .about p { color: var(--text-dim); margin-bottom: 20px; font-size: 16.5px; }
  
  .snapshot-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 32px; }
  .snapshot-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 20px;
    box-shadow: 0 4px 12px var(--shadow); transition: var(--transition);
  }
  .snapshot-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .snapshot-card-title { font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent); font-weight: 700; margin-bottom: 6px; }
  .snapshot-card-val { font-size: 15px; font-weight: 600; color: var(--text); }

  /* BENTO LAYOUT VALUE SECTION */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 20px;
    margin-top: 40px;
  }
  .bento-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 32px;
    box-shadow: 0 6px 16px var(--shadow); display: flex; flex-direction: column;
    justify-content: flex-end; transition: var(--transition); position: relative; overflow: hidden;
  }
  .bento-card:hover { transform: translateY(-4px); border-color: var(--accent); box-shadow: 0 12px 28px var(--shadow-hover); }
  
  /* Bento Size Modifiers */
  .bento-w2 { grid-column: span 2; }
  .bento-h2 { grid-row: span 2; justify-content: space-between; }
  
  .bento-icon {
    width: 44px; height: 44px; border-radius: 12px; background: rgba(242, 157, 165, 0.1);
    color: var(--accent); display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: bold; margin-bottom: 24px;
  }
  .bento-card h3 { font-family: "Playfair Display", Georgia, serif; font-size: 22px; font-weight: 700; margin-bottom: 8px; }
  .bento-card p { color: var(--text-dim); font-size: 14px; line-height: 1.5; }

  /* OUTCOME-BASED SERVICES GRID */
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px; }
  .service-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 36px;
    box-shadow: 0 6px 18px var(--shadow); transition: var(--transition); display: flex; flex-direction: column;
  }
  .service-card:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 28px var(--shadow-hover); }
  .service-num-marker { font-family: "Playfair Display", serif; font-size: 14px; color: var(--accent); font-weight: bold; margin-bottom: 16px; }
  .service-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 12px; }
  .service-card p { color: var(--text-dim); font-size: 14.5px; margin-bottom: 24px; flex-grow: 1; }
  .service-outcome-pill {
    background: var(--bg-alt); border-radius: 8px; padding: 10px 14px; font-size: 13px;
    font-weight: 600; color: var(--text); border-left: 3px solid var(--accent);
  }

  /* PREMIUM FEATURED WORKSPACE PLATFORM MOCKUPS */
  .featured-workspace { background: var(--bg-alt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .case-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; margin-top: 16px; }
  
  .premium-case-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 28px; padding: 40px;
    box-shadow: 0 10px 30px var(--shadow); display: flex; flex-direction: column; justify-content: space-between;
    transition: var(--transition);
  }
  .premium-case-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 16px 40px var(--shadow-hover); }
  
  .case-content-top h3 { font-family: "Playfair Display", Georgia, serif; font-size: 26px; font-weight: 700; margin-bottom: 12px; }
  .case-content-top p { color: var(--text-dim); font-size: 15px; margin-bottom: 32px; }
  
  /* Platform Mockup Panels */
  .mockup-panel {
    width: 100%; aspect-ratio: 16/10; background: #131110; border-radius: 16px;
    margin-bottom: 32px; border: 1px solid rgba(255,255,255,0.08); overflow: hidden; position: relative;
  }
  
  /* YouTube Layout Panel */
  .yt-mockup { display: flex; flex-direction: column; justify-content: flex-end; background: #181615; }
  .yt-visual-placeholder {
    position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.3); font-size: 12px; gap: 8px;
  }
  .yt-play-overlay {
    width: 56px; height: 56px; background: #ff0000; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; color: #fff; font-size: 20px;
    box-shadow: 0 0 24px rgba(255,0,0,0.5);
  }
  .yt-bottom-info-strip {
    background: #0f0e0d; padding: 14px 20px; display: flex; align-items: center; gap: 12px; z-index: 2;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .yt-avatar-circle { width: 36px; height: 36px; background: var(--accent); border-radius: 50%; }
  .yt-meta-text { font-size: 13px; font-weight: 700; color: #ffffff; }
  .yt-meta-sub { font-size: 11px; color: #8a827c; margin-top: 1px; }

  /* Browser Mockup Panel */
  .browser-mockup { background: #ffffff; display: flex; flex-direction: column; border: 1px solid var(--border); }
  .browser-top-nav-bar {
    background: #f1ebd9; padding: 10px 16px; display: flex; align-items: center; gap: 24px;
    border-bottom: 1px solid var(--border);
  }
  .browser-dots-cluster { display: flex; gap: 6px; }
  .browser-dot-node { width: 8px; height: 8px; background: var(--text-dim); border-radius: 50%; opacity: 0.4; }
  .browser-url-field {
    background: var(--card); border-radius: 6px; padding: 4px 16px; font-size: 11px;
    color: var(--text); font-weight: 600; flex-grow: 1; max-width: 320px; border: 1px solid var(--border);
  }
  .browser-view-canvas {
    flex-grow: 1; background: #0b0f19; display: flex; flex-direction: column; align-items: center;
    justify-content: center; color: #3cd070; font-family: monospace; font-size: 12px; gap: 6px;
  }
  [data-theme="dark"] .browser-mockup { background: #1c1815; }
  [data-theme="dark"] .browser-top-nav-bar { background: #26201c; }

  /* TRACK RECORD EXPERIENCE BLOCKS */
  .experience-timeline { display: flex; flex-direction: column; gap: 24px; }
  .exp-block {
    background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 40px;
    display: grid; grid-template-columns: 280px 1fr; gap: 48px; box-shadow: 0 4px 14px var(--shadow);
  }
  .exp-left-title h3 { font-family: "Playfair Display", Georgia, serif; font-size: 22px; font-weight: 700; }
  .exp-right-body p { color: var(--text-dim); font-size: 16px; margin-bottom: 24px; }
  .exp-pill-cloud { display: flex; flex-wrap: wrap; gap: 8px; }
  .exp-pill-cloud span {
    background: var(--bg-alt); border: 1px solid var(--border); font-size: 13px; padding: 6px 14px;
    border-radius: 999px; font-weight: 500; color: var(--text);
  }

  /* TOOL AND INFRASTRUCTURE GRID */
  .tools-section { background: var(--bg-alt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .tool-group-box { margin-bottom: 40px; }
  .tool-group-box:last-child { margin-bottom: 0; }
  .tool-group-header { font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 20px; font-weight: 700; }
  
  .tool-badge-flex { display: flex; flex-wrap: wrap; gap: 12px; }
  .tool-badge-item {
    background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 12px 20px;
    display: flex; align-items: center; gap: 10px; box-shadow: 0 2px 6px var(--shadow);
  }
  .tool-badge-item .badge-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  .tool-badge-item span { font-weight: 600; font-size: 14px; }

  /* PERSISTENT PROCESS WORKFLOW LINES */
  .process-grid-6step { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px 32px; }
  .process-node-card { border-top: 2px solid var(--border); padding-top: 24px; transition: var(--transition); }
  .process-node-card:hover { border-color: var(--accent); }
  .process-step-num { font-family: "Playfair Display", serif; font-size: 14px; color: var(--accent); font-weight: 700; margin-bottom: 12px; }
  .process-node-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .process-node-card p { color: var(--text-dim); font-size: 14.5px; }

  /* CALL TO ACTION HUB */
  .cta-hub { text-align: center; background: var(--bg); padding: 120px 0; }
  .cta-hub-interior { max-width: 680px; margin: 0 auto; padding: 0 24px; }
  .cta-hub h2 { font-size: clamp(34px, 5vw, 52px); margin-bottom: 20px; }
  .cta-hub p { font-size: 18px; color: var(--text-dim); margin-bottom: 40px; }

  .contact-footer-block { background: var(--bg-alt); text-align: center; padding: 80px 0 40px; border-top: 1px solid var(--border); }
  .interactive-social-row { display: flex; justify-content: center; gap: 24px; margin: 40px 0; }
  
  .social-anchor-circle {
    width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--border);
    background: var(--card); display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700; color: var(--text); box-shadow: 0 4px 10px var(--shadow);
  }
  .social-anchor-circle:hover { border-color: var(--accent); background: var(--accent); color: var(--accent-ink); transform: scale(1.08); }

  footer { border-top: 1px solid var(--border); padding: 32px 0; text-align: center; color: var(--text-dim); font-size: 13.5px; background: var(--bg-alt); }

  /* RESPONSIVE BREAKPOINTS ENGINE */
  @media (max-width: 960px) {
    .hero-grid, .about-grid, .case-grid, .exp-block { grid-template-columns: 1fr; gap: 40px; }
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
    .bento-w2 { grid-column: span 1; }
    .process-grid-6step { grid-template-columns: repeat(2, 1fr); }
    .hero-grid .photo-frame { order: -1; aspect-ratio: 16/9; }
  }
  @media (max-width: 640px) {
    .bento-grid, .process-grid-6step { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .stats { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
</head>
