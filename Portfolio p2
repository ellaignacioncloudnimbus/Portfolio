<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ella Joy Ignacio — YouTube Growth & Content Operations</title>
<!-- Clean Web Fonts Hierarchy -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">

<style>
  /* DESIGN FRAMEWORK EMULATOR & ROOT TOKENS */
  :root {
    --bg: #faf7f2;        /* Premium Cream Milk Tea */
    --bg-alt: #f3ede2;    /* Soft Warm Contrast Shadow */
    --card: #ffffff;      /* Pure Crisp Card Bases */
    --border: #e6dcce;    /* Soft Muted Taupe Binding Line */
    --text: #3d2f28;      /* Luxe Earth Espresso */
    --text-dim: #8c7a6b;  /* Mid Tone Slate Sand */
    --accent: #f29da5;    /* Luxury Aesthetic Dusty Rose Blush Pink */
    --accent-dim: #df848d;
    --accent-ink: #ffffff;
    --shadow: rgba(61, 47, 39, 0.04);
    --shadow-hover: rgba(61, 47, 39, 0.09);
    --radius-lg: 24px;
    --radius-md: 16px;
    --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-theme="dark"] {
    --bg: #0c0a09;        /* Dark Minimal Obsidian Ink */
    --bg-alt: #141210;    /* Dark Charcoal Cocoa */
    --card: #1a1715;      /* Deep Onyx Slate */
    --border: #2c2521;    /* Earth Bark Divider */
    --text: #f5f0eb;      /* Cream Silk Contrast */
    --text-dim: #a89a8e;  /* Ash Muted Taupe Sand */
    --accent: #f5aeb5;    /* Glowing Pastel Blush Pink */
    --accent-dim: #f29da5;
    --accent-ink: #1a1715;
    --shadow: rgba(0, 0, 0, 0.3);
    --shadow-hover: rgba(0, 0, 0, 0.4);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; scroll-padding-top: 100px; }
  body {
    background: var(--bg); color: var(--text);
    font-family: "Plus Jakarta Sans", sans-serif;
    line-height: 1.6; overflow-x: hidden;
    transition: background var(--transition), color var(--transition);
  }
  a { color: inherit; text-decoration: none; }
  .wrap { max-width: 1140px; margin: 0 auto; padding: 0 24px; }

  /* NAVIGATION BAR WITH HIGHLY VISIBLE SYSTEM TOGGLE BUTTON */
  header {
    position: sticky; top: 0; z-index: 1000;
    background: var(--bg); border-bottom: 1px solid var(--border);
    transition: background var(--transition), border-color var(--transition);
  }
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 0;
  }
  .logo {
    font-family: "Playfair Display", serif; font-weight: 700; font-size: 22px;
  }
  .logo span { color: var(--accent); font-style: italic; font-weight: 400; }
  
  .nav-right { display: flex; align-items: center; gap: 24px; }
  .nav-links { display: flex; gap: 28px; font-size: 14px; font-weight: 500; color: var(--text-dim); }
  .nav-links a:hover { color: var(--text); }
  
  /* The Explicit Visual Theme Switcher Control */
  .theme-switch-container {
    display: flex; align-items: center; gap: 8px;
    background: var(--bg-alt); padding: 4px 8px; border-radius: 999px;
    border: 1px solid var(--border); transition: var(--transition);
  }
  .theme-toggle-node {
    background: none; border: none; cursor: pointer;
    padding: 6px 12px; font-size: 13px; font-weight: 600; border-radius: 999px;
    color: var(--text-dim); display: flex; align-items: center; gap: 6px; transition: var(--transition);
  }
  .theme-toggle-node.active {
    background: var(--card); color: var(--text); box-shadow: 0 2px 6px var(--shadow);
  }

  .nav-cta {
    border: 1px solid var(--accent); color: var(--accent);
    padding: 10px 20px; border-radius: 999px; font-size: 13px; font-weight: 600;
  }
  .nav-cta:hover { background: var(--accent); color: var(--accent-ink); }

  /* SCROLL FADE-UP CLASS STRUCTURES (INTERSECTION OBSERVER) */
  .reveal {
    opacity: 0; transform: translateY(32px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.active { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  }

  /* SECTION LABELS */
  section { padding: 100px 0; }
  .section-tag {
    display: inline-block; font-size: 12px; color: var(--accent);
    letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; font-weight: 700;
  }
  h2 {
    font-family: "Playfair Display", serif; font-size: clamp(32px, 4vw, 44px);
    font-weight: 700; letter-spacing: -0.01em; line-height: 1.2; margin-bottom: 16px;
  }
  .section-intro { color: var(--text-dim); max-width: 620px; font-size: 17px; margin-bottom: 56px; }

  /* HERO AREA ARRANGEMENT */
  .hero { padding: 120px 0 80px; border-bottom: 1px solid var(--border); }
  .hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 56px; align-items: center; }
  
  .image-placeholder-frame {
    background: var(--card); border: 1px dashed var(--border); border-radius: var(--radius-lg);
    aspect-ratio: 4/5; display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; color: var(--text-dim); font-size: 14px; text-align: center; padding: 24px;
    box-shadow: 0 10px 30px var(--shadow); position: relative;
  }
  .image-placeholder-frame .frame-icon {
    width: 52px; height: 52px; border-radius: 50%; background: rgba(242, 157, 165, 0.12);
    color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 20px;
  }

  .hero h1 { font-family: "Playfair Display", serif; font-size: clamp(40px, 5.5vw, 64px); font-weight: 700; line-height: 1.1; margin-bottom: 24px; }
  .hero h1 span.accent { color: var(--accent); font-style: italic; font-weight: 400; }
  .hero p.sub { font-size: 18px; color: var(--text-dim); max-width: 560px; margin-bottom: 40px; }

  /* REDESIGNED QUICK PROFILE SECTION (PREMIUM PROFILED CARDS) */
  .about { background: var(--bg-alt); border-bottom: 1px solid var(--border); }
  .about-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: start; }
  .about-text p { color: var(--text-dim); margin-bottom: 20px; font-size: 16.5px; }
  
  .premium-snapshot-container {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 32px;
  }
  .profile-badge-card {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-md);
    padding: 20px; box-shadow: 0 4px 12px var(--shadow); transition: var(--transition);
    display: flex; flex-direction: column; gap: 8px;
  }
  .profile-badge-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 20px var(--shadow-hover); }
  .badge-meta-icon { font-size: 18px; width: max-content; color: var(--accent); }
  .badge-meta-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-dim); font-weight: 700; }
  .badge-meta-value { font-size: 14.5px; font-weight: 600; color: var(--text); }

  /* REDESIGNED BENTO GRID FOR VALUE PACK PROPOSITION */
  .bento-matrix {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px;
  }
  .bento-block {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px;
    box-shadow: 0 4px 14px var(--shadow); display: flex; flex-direction: column; justify-content: space-between;
    transition: var(--transition); position: relative; min-height: 220px;
  }
  .bento-block:hover { transform: translateY(-4px); border-color: var(--accent); box-shadow: 0 12px 24px var(--shadow-hover); }
  
  .bento-w2 { grid-column: span 2; }
  .bento-h2 { grid-row: span 2; min-height: 460px; }
  
  .bento-graphic-node {
    width: 44px; height: 44px; border-radius: 12px; background: rgba(242, 157, 165, 0.1);
    color: var(--accent); display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: bold; margin-bottom: 24px;
  }
  .bento-block h3 { font-family: "Playfair Display", serif; font-size: 22px; font-weight: 700; margin-bottom: 8px; }
  .bento-block p { color: var(--text-dim); font-size: 14px; line-height: 1.5; }

  /* OUTCOME SERVICES MATRIX */
  .services-layout { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px; }
  .service-box {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 36px;
    box-shadow: 0 4px 14px var(--shadow); transition: var(--transition); display: flex; flex-direction: column;
  }
  .service-box:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 24px var(--shadow-hover); }
  .service-index { font-family: "Playfair Display", serif; font-size: 13px; color: var(--accent); font-weight: bold; margin-bottom: 16px; }
  .service-box h3 { font-size: 19px; font-weight: 700; margin-bottom: 12px; }
  .service-box p { color: var(--text-dim); font-size: 14.5px; margin-bottom: 24px; flex-grow: 1; }
  .service-pill-outcome {
    background: var(--bg-alt); border-radius: 8px; padding: 10px 14px; font-size: 13px;
    font-weight: 600; color: var(--text); border-left: 3px solid var(--accent);
  }

  /* REDESIGNED FEATURED WORKSPACE PREVIEW MOCKUP CARDS */
  .workspace-showcase { background: var(--bg-alt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .mockup-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; margin-top: 16px; }
  
  .mockup-case-card {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 40px;
    box-shadow: 0 10px 30px var(--shadow); display: flex; flex-direction: column; justify-content: space-between;
    transition: var(--transition);
  }
  .mockup-case-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 16px 40px var(--shadow-hover); }
  .mockup-case-card h3 { font-family: "Playfair Display", serif; font-size: 24px; font-weight: 700; margin-bottom: 6px; }
  .mockup-case-card .sub-header-link { font-size: 13px; color: var(--accent); font-weight: 600; margin-bottom: 16px; display: block; }
  .mockup-case-card p.desc { color: var(--text-dim); font-size: 15px; margin-bottom: 32px; }
  
  /* Canvas Visual Frame Bases */
  .visual-canvas-frame {
    width: 100%; aspect-ratio: 16/10; background: #14110f; border-radius: 16px;
    margin-bottom: 32px; border: 1px solid rgba(255,255,255,0.06); overflow: hidden; position: relative;
  }
  
  /* YouTube Render Framework */
  .yt-render-canvas { display: flex; flex-direction: column; justify-content: flex-end; background: #1b1715; }
  .yt-render-interior {
    position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.3); font-size: 12px; gap: 8px; background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.8) 100%);
  }
  .yt-play-node-icon {
    width: 52px; height: 52px; background: #ff0000; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; color: #fff; font-size: 18px;
    box-shadow: 0 0 20px rgba(255,0,0,0.4);
  }
  .yt-metadata-dock {
    background: #0f0d0c; padding: 14px 20px; display: flex; align-items: center; gap: 12px; z-index: 5;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .yt-dock-avatar { width: 34px; height: 34px; background: var(--accent); border-radius: 50%; }
  .yt-dock-text { font-size: 13px; font-weight: 700; color: #ffffff; }
  .yt-dock-text span { font-size: 11px; color: #8c8178; display: block; font-weight: 400; margin-top: 1px; }

  /* Web Domain Browser Mockup */
  .web-render-canvas { background: #ffffff; display: flex; flex-direction: column; border: 1px solid var(--border); }
  .web-window-header {
    background: #eee8dc; padding: 10px 16px; display: flex; align-items: center; gap: 16px;
    border-bottom: 1px solid var(--border);
  }
  .web-header-circles { display: flex; gap: 5px; }
  .web-circle-node { width: 8px; height: 8px; background: var(--text-dim); border-radius: 50%; opacity: 0.3; }
  .web-url-bar-box {
    background: var(--card); border-radius: 6px; padding: 4px 14px; font-size: 11px;
    color: var(--text); font-weight: 600; flex-grow: 1; max-width: 260px; border: 1px solid var(--border);
  }
  .web-content-viewports {
    flex-grow: 1; background: #0c0f17; display: flex; flex-direction: column; align-items: center;
    justify-content: center; color: #42d174; font-family: monospace; font-size: 12px; gap: 6px;
  }
  [data-theme="dark"] .web-render-canvas { background: #1a1715; }
  [data-theme="dark"] .web-window-header { background: #26211d; }

  /* TRACK TIMELINE ROW BLOCKS */
  .timeline-container { display: flex; flex-direction: column; gap: 24px; }
  .timeline-row-card {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 40px;
    display: grid; grid-template-columns: 260px 1fr; gap: 48px; box-shadow: 0 4px 12px var(--shadow);
  }
  .timeline-row-card h3 { font-family: "Playfair Display", serif; font-size: 22px; font-weight: 700; }
  .timeline-row-card p { color: var(--text-dim); font-size: 16px; margin-bottom: 24px; }
  .timeline-tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }
  .timeline-tag-cloud span {
    background: var(--bg-alt); border: 1px solid var(--border); font-size: 13px; padding: 6px 14px;
    border-radius: 999px; font-weight: 500; color: var(--text);
  }

  /* TOOL STRIP LOGIC */
  .tools-section { background: var(--bg-alt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .tool-box-container { margin-bottom: 40px; }
  .tool-box-container:last-child { margin-bottom: 0; }
  .tool-box-header { font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 20px; font-weight: 700; }
  .tool-badges-row { display: flex; flex-wrap: wrap; gap: 12px; }
  .tool-badge-node {
    background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 12px 20px;
    display: flex; align-items: center; gap: 10px; box-shadow: 0 2px 6px var(--shadow);
  }
  .tool-badge-node .node-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  .tool-badge-node span { font-weight: 600; font-size: 14px; }

  /* 6-STEP WORK PIPELINE BLOCKS */
  .pipeline-grid-6step { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px 32px; }
  .pipeline-step-card { border-top: 2px solid var(--border); padding-top: 24px; transition: var(--transition); }
  .pipeline-step-card:hover { border-color: var(--accent); }
  .pipeline-step-index { font-family: "Playfair Display", serif; font-size: 14px; color: var(--accent); font-weight: 700; margin-bottom: 12px; }
  .pipeline-step-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .pipeline-step-card p { color: var(--text-dim); font-size: 14.5px; }

  /* CALL TO ACTION LAYOUTS */
  .cta-hub-panel { text-align: center; background: var(--bg); padding: 120px 0; }
  .cta-hub-box { max-width: 680px; margin: 0 auto; padding: 0 24px; }
  .cta-hub-panel h2 { font-size: clamp(34px, 5vw, 48px); margin-bottom: 20px; }
  .cta-hub-panel p { font-size: 18px; color: var(--text-dim); margin-bottom: 40px; }

  .contact-footer-dock { background: var(--bg-alt); text-align: center; padding: 80px 0 40px; border-top: 1px solid var(--border); }
  .footer-social-row { display: flex; justify-content: center; gap: 24px; margin: 40px 0; }
  
  .footer-social-badge {
    width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--border);
    background: var(--card); display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700; color: var(--text); box-shadow: 0 4px 10px var(--shadow);
    transition: var(--transition);
  }
  .footer-social-badge:hover { border-color: var(--accent); background: var(--accent); color: var(--accent-ink); transform: scale(1.08); }

  footer { border-top: 1px solid var(--border); padding: 32px 0; text-align: center; color: var(--text-dim); font-size: 13.5px; background: var(--bg-alt); }

  /* MOBILE MEDIA QUERY ENGINES */
  @media (max-width: 960px) {
    .hero-grid, .about-grid, .mockup-grid, .timeline-row-card { grid-template-columns: 1fr; gap: 40px; }
    .bento-matrix { grid-template-columns: repeat(2, 1fr); }
    .bento-w2 { grid-column: span 1; }
    .pipeline-grid-6step { grid-template-columns: repeat(2, 1fr); }
    .hero-grid .image-placeholder-frame { order: -1; aspect-ratio: 16/9; }
  }
  @media (max-width: 640px) {
    .bento-matrix, .pipeline-grid-6step { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .stats { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
</head>
