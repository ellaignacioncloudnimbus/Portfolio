<script>
  /* 1. VISUAL VISITOR THEME TOGGLE SWITCH SEGMENT CONTROL LOGIC */
  const lightBtn = document.getElementById('lightThemeToggleBtn');
  const darkBtn = document.getElementById('darkThemeToggleBtn');
  
  function applyTheme(themeName) {
    document.documentElement.setAttribute('data-theme', themeName);
    localStorage.setItem('theme', themeName);
    
    if (themeName === 'dark') {
      darkBtn.classList.add('active');
      lightBtn.classList.remove('active');
    } else {
      lightBtn.classList.add('active');
      darkBtn.classList.remove('active');
    }
  }

  // Initialization checking sequence
  const cachedThemeSetting = localStorage.getItem('theme');
  const userSystemDarkActive = window.matchMedia('(prefers-color-scheme: dark)').matches;
  
  if (cachedThemeSetting === 'dark' || (!cachedThemeSetting && userSystemDarkActive)) {
    applyTheme('dark');
  } else {
    applyTheme('light');
  }

  lightBtn.addEventListener('click', () => applyTheme('light'));
  darkBtn.addEventListener('click', () => applyTheme('dark'));

  /* 2. INTERSECTION OBSERVER SCROLL ELEVATION CONTROL SYSTEM */
  const scrollElementsNodeList = document.querySelectorAll('.reveal');
  
  const observerConfigOptions = {
    threshold: 0.05,
    rootMargin: "0px 0px -40px 0px"
  };

  const runtimeIntersectionObserver = new IntersectionObserver((observedEntries, contentObserver) => {
    observedEntries.forEach((entryElement, targetIndex) => {
      if (entryElement.isIntersecting) {
        setTimeout(() => {
          entryElement.target.classList.add('active');
        }, targetIndex * 40);
        contentObserver.unobserve(entryElement.target);
      }
    });
  }, observerConfigOptions);

  scrollElementsNodeList.forEach(activeNode => runtimeIntersectionObserver.observe(activeNode));
</script>

