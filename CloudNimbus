<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cloud Nimbus | Digital Operations & Growth Studio</title>
  <meta name="description" content="Cloud Nimbus helps creators, founders, and small businesses with website management, YouTube operations, content systems, SEO, virtual assistance, and digital growth support." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>
    :root {
      --bg: #f6fbff;
      --bg-2: #eaf5ff;
      --card: rgba(255,255,255,.82);
      --card-solid: #ffffff;
      --text: #071827;
      --muted: #5d7083;
      --border: rgba(11, 39, 66, .12);
      --accent: #5ab6ff;
      --accent-2: #1f7fd1;
      --navy: #071827;
      --shadow: 0 24px 70px rgba(11, 39, 66, .13);
      --radius-xl: 32px;
      --radius-lg: 24px;
      --radius-md: 16px;
      --max: 1160px;
      --transition: 240ms ease;
    }

    html[data-theme="dark"] {
      --bg: #050b14;
      --bg-2: #09182b;
      --card: rgba(12, 27, 48, .78);
      --card-solid: #0b1627;
      --text: #eef8ff;
      --muted: #9eb4c8;
      --border: rgba(154, 200, 255, .16);
      --accent: #69bdff;
      --accent-2: #3d8ee8;
      --shadow: 0 24px 70px rgba(0,0,0,.45);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Inter, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(90,182,255,.22), transparent 36%),
        radial-gradient(circle at 85% 20%, rgba(61,142,232,.18), transparent 30%),
        linear-gradient(180deg, var(--bg), var(--bg-2));
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    .wrap { max-width: var(--max); margin: auto; padding: 0 22px; }

    header {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: color-mix(in srgb, var(--bg) 82%, transparent);
      border-bottom: 1px solid var(--border);
    }

    nav {
      height: 78px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 900;
      letter-spacing: .14em;
      text-transform: uppercase;
    }

    .logo-mark {
      width: 46px;
      height: 46px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(105,189,255,.22), rgba(61,142,232,.08));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .logo-mark svg { width: 31px; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 22px;
      color: var(--muted);
      font-size: 14px;
      font-weight: 700;
    }

    .theme-toggle {
      border: 1px solid var(--border);
      background: var(--card);
      color: var(--text);
      padding: 10px 14px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 800;
    }

    section { padding: 96px 0; }

    .hero { padding-top: 110px; }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 54px;
      align-items: center;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--card);
      color: var(--accent);
      font-size: 13px;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    h1 {
      font-size: clamp(44px, 7vw, 78px);
      line-height: .95;
      letter-spacing: -.06em;
      margin-bottom: 24px;
    }

    h1 span, .accent { color: var(--accent); }

    h2 {
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1;
      letter-spacing: -.045em;
      margin-bottom: 18px;
    }

    .lead {
      color: var(--muted);
      font-size: 18px;
      max-width: 680px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 34px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 15px 20px;
      border-radius: 999px;
      font-weight: 900;
      transition: var(--transition);
      border: 1px solid var(--border);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #04101d;
      box-shadow: 0 18px 45px rgba(90,182,255,.28);
    }

    .btn-secondary {
      background: var(--card);
      color: var(--text);
    }

    .btn:hover { transform: translateY(-3px); }

    .hero-card {
      border: 1px solid var(--border);
      background: linear-gradient(145deg, var(--card), rgba(90,182,255,.08));
      border-radius: var(--radius-xl);
      padding: 34px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .hero-card:before {
      content: "";
      position: absolute;
      width: 220px;
      height: 220px;
      background: var(--accent);
      filter: blur(90px);
      opacity: .16;
      right: -70px;
      top: -50px;
    }

    .big-logo {
      position: relative;
      display: grid;
      place-items: center;
      min-height: 280px;
      border-radius: 26px;
      background: rgba(255,255,255,.04);
      border: 1px solid var(--border);
      margin-bottom: 24px;
    }

    .big-logo svg { width: 190px; max-width: 70%; }

    .mini-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 24px;
    }

    .stat {
      padding: 16px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: var(--card);
    }

    .stat strong {
      display: block;
      color: var(--accent);
      font-size: 22px;
      line-height: 1;
    }

    .stat span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 38px;
    }

    .card {
      border: 1px solid var(--border);
      background: var(--card);
      border-radius: var(--radius-lg);
      padding: 26px;
      box-shadow: var(--shadow);
      transition: var(--transition);
    }

    .card:hover {
      transform: translateY(-6px);
      border-color: var(--accent);
    }

    .icon {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: rgba(90,182,255,.12);
      color: var(--accent);
      font-size: 21px;
      margin-bottom: 18px;
    }

    .card h3 { font-size: 20px; margin-bottom: 10px; }
    .card p { color: var(--muted); font-size: 15px; }

    .about-grid {
      display: grid;
      grid-template-columns: .85fr 1.15fr;
      gap: 24px;
      align-items: stretch;
    }

    .founder-card {
      background: linear-gradient(145deg, rgba(90,182,255,.16), var(--card));
    }

    .founder-name { font-size: 28px; margin-bottom: 8px; }
    .role { color: var(--accent); font-weight: 900; margin-bottom: 18px; }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 22px;
    }

    .pill {
      padding: 9px 12px;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--muted);
      background: rgba(255,255,255,.04);
      font-size: 13px;
      font-weight: 800;
    }

    .process {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 38px;
    }

    .step-num {
      color: var(--accent);
      font-weight: 900;
      letter-spacing: .12em;
      margin-bottom: 12px;
    }

    .work-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      align-items: center;
      margin-top: 38px;
    }

    .preview {
      min-height: 280px;
      border-radius: 24px;
      border: 1px solid var(--border);
      background:
        linear-gradient(135deg, rgba(90,182,255,.18), transparent),
